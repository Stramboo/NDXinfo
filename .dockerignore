# ============================================================
# NDXinfo Docker 构建忽略文件
# 排除无需打包进镜像的文件，减小镜像体积、加速构建
# ============================================================

# --- Python 缓存与编译文件 ---
__pycache__/
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg

# --- Git 版本控制目录 ---
.git/
.gitignore
.gitattributes

# --- 运行时生成的数据与报告（容器内重新生成）---
data/
reports/
output/

# --- 根目录下已生成的 HTML 报告（运行时重新生成）---
# 注意：使用 /* 锚定根目录，不影响 templates/report_template.html 模板
/*.html

# --- 虚拟环境 ---
.venv/
venv/
env/

# --- IDE 与编辑器配置 ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Trae 工作目录 ---
.trae/

# --- 日志文件 ---
*.log

# --- CI / 部署配置（无需进入镜像）---
.github/
Dockerfile
.dockerignore

# --- 系统杂项文件 ---
.DS_Store
Thumbs.db
desktop.ini

# --- 文档与许可（运行不需要）---
README.md
LICENSE
